# =============================================================================
# AutoCTR — LOCAL WORKER MACHINE .env example
# =============================================================================
# Copy to `.env` for local PM2 worker hosts. The dashboard runs on Vercel and
# uses its own env vars (see dashboard/.env.example).
#
# DO NOT set `TZ` — Vercel reserves it. Use APP_TIMEZONE instead.
# =============================================================================

# Required — Neon PostgreSQL connection string (same DB the Vercel dashboard uses).
DATABASE_URL=postgres://...

# Required by src/config (workers don't sign tokens, but the var must exist).
JWT_SECRET=change_me_to_at_least_32_chars

# Required — Shoplike rotating-proxy API keys (comma-separated). Shared across
# all PM2 workers via a cooldown-aware in-process pool (~60s rotation per key).
SHOPLIKE_API_KEYS=

# Optional — RektCaptcha Chrome extension path (unpacked, relative to root).
REKTCAPTCHA_PATH=./extensions/rektcaptcha

# Optional — IANA timezone for scheduling. Defaults to Asia/Dubai.
APP_TIMEZONE=Asia/Dubai

# Optional — total in-flight traffic jobs across all PM2 workers. One job per
# worker, so this is also the PM2 instance count. Defaults to host CPU cores.
WORKER_CONCURRENCY=
