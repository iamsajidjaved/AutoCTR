DATABASE_URL=postgres://...
JWT_SECRET=change_me_to_at_least_32_chars
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
# Process & DB session timezone. Defaults to Asia/Dubai if unset. Must be a valid IANA tz.
TZ=Asia/Dubai
# Comma-separated Shoplike rotating-proxy API keys (one PM2 worker per key).
SHOPLIKE_API_KEYS=
REKTCAPTCHA_PATH=./extensions/rektcaptcha
