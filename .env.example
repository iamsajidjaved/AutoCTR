# Database — Neon (PostgreSQL)
# Get connection string from Neon dashboard → your project → Connection Details
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_HOST=
DATABASE_POOLER_HOST=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# App
PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_to_at_least_32_random_characters

# Frontend
FRONTEND_URL=http://localhost:3001

# Proxy providers
# Shop Like Proxy — get key at proxy.shoplike.vn
SHOPLIKE_API_KEY=

# RektCaptcha Chrome extension — unpack to this path before running workers
# See spec-09 for setup instructions
REKTCAPTCHA_PATH=./extensions/rektcaptcha
