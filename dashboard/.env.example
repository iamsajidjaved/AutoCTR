# --- Required (Vercel Production Environment Variables) ---
# Neon PostgreSQL connection string. Same database the local PM2 workers use
# (workers query Neon directly via @neondatabase/serverless).
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# JWT signing secret. MUST match the value the workers use if you ever sign or
# verify tokens worker-side. (Workers currently don't, so it can be a separate
# secret if you prefer — just pin a long random value here.)
JWT_SECRET=replace-with-a-long-random-string

# --- Optional ---
# IANA timezone for analytics bucketing and dashboard display. Vercel reserves
# `TZ` and forces UTC for serverless functions; we use APP_TIMEZONE instead.
APP_TIMEZONE=Asia/Dubai

# --- Client-side override ---
# Leave UNSET on Vercel — same-origin requests go to /api/* automatically.
# Only set during local dev if pointing the dashboard at a remote API.
# NEXT_PUBLIC_API_URL=
