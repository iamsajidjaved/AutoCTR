{
  "name": "autoctr-worker",
  "version": "1.0.0",
  "description": "AutoCTR — local PM2 traffic workers (the Vercel-hosted dashboard lives in /dashboard)",
  "main": "src/workers/trafficWorker.js",
  "scripts": {
    "worker": "node src/workers/trafficWorker.js",
    "worker:pm2": "pm2 start ecosystem.config.js",
    "worker:logs": "pm2 logs ctr-worker",
    "worker:stop": "pm2 stop ecosystem.config.js && pm2 delete ecosystem.config.js",
    "db:migrate": "node src/models/migrate.js",
    "dashboard": "cd dashboard && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.1.14"
  }
}
